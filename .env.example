# ============================================================
# CCS CODE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- UHG Corporate Provider --------------------------------
# Obtain from your UHG/UAIS API gateway registration.
CCS_UHG_CLIENT_ID=your-client-id-here
CCS_UHG_CLIENT_SECRET=your-client-secret-here

# ----- Personal OpenAI Provider ------------------------------
CCS_OPENAI_API_KEY=sk-...

# ----- Personal Anthropic Provider ---------------------------
CCS_ANTHROPIC_API_KEY=sk-ant-...
