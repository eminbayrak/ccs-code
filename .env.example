# ============================================================
# CCS CODE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Enterprise Corporate Provider ---------------------------
# Obtain from your Enterprise API gateway registration.
CCS_ENTERPRISE_CLIENT_ID=your-client-id-here
CCS_ENTERPRISE_CLIENT_SECRET=your-client-secret-here
CCS_ENTERPRISE_AUTH_URL=https://api.enterprise.com/oauth2/token
CCS_ENTERPRISE_SCOPE=https://api.enterprise.com/.default
CCS_ENTERPRISE_API_BASE=https://api.enterprise.com/api/v1/ai-gateway

# ----- Personal OpenAI Provider ------------------------------
CCS_OPENAI_API_KEY=sk-...

# ----- Personal Anthropic Provider ---------------------------
CCS_ANTHROPIC_API_KEY=sk-ant-...

GITHUB_PRIVATE_TOKEN=