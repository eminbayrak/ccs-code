{
  "name": "ccs-code",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.tsx",
    "dev": "bun --watch src/main.tsx",
    "build": "bun build ./src/main.tsx --compile --outfile ccs",
    "build:plugins": "bun build ./plugins/migrate-soap/index.ts --outfile ./plugins/migrate-soap/index.js --format esm",
    "build:all": "bun run build && bun run build:plugins",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cli-spinners": "^2.0.0",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "chalk": "4",
    "cli-spinners": "^3.4.0",
    "commander": "^14.0.3",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "tree-sitter": "^0.21.1",
    "tree-sitter-python": "*",
    "tree-sitter-java": "*",
    "tree-sitter-c-sharp": "*",
    "tree-sitter-go": "*",
    "tree-sitter-c": "*",
    "tree-sitter-cpp": "*",
    "tree-sitter-pascal": "*"
  }
}
